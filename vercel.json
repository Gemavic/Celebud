{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://bwtrtzvlqvykobmlfjcl.supabase.co/functions/v1/Generate-sitemap"
    },
    {
      "source": "/news-sitemap.xml",
      "destination": "https://bwtrtzvlqvykobmlfjcl.supabase.co/functions/v1/Generate-sitemap?type=news"
    },
    {
      "source": "/feed.xml",
      "destination": "https://bwtrtzvlqvykobmlfjcl.supabase.co/functions/v1/Generate-sitemap?type=rss"
    },
    {
      "source": "/rss.xml",
      "destination": "https://bwtrtzvlqvykobmlfjcl.supabase.co/functions/v1/Generate-sitemap?type=rss"
    },
    {
      "source": "/article/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|yandex|duckduckbot|baiduspider|facebookexternalhit|facebookcatalog|twitterbot|linkedinbot|slackbot|discordbot|whatsapp|telegrambot|pinterest|redditbot|applebot|petalbot).*"
        }
      ],
      "destination": "https://bwtrtzvlqvykobmlfjcl.supabase.co/functions/v1/Prerender?path=/article/$1"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|yandex|duckduckbot|baiduspider|facebookexternalhit|facebookcatalog|twitterbot|linkedinbot|slackbot|discordbot|whatsapp|telegrambot|pinterest|redditbot|applebot|petalbot).*"
        }
      ],
      "destination": "https://bwtrtzvlqvykobmlfjcl.supabase.co/functions/v1/Prerender?path=/"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/ads.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
