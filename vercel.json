{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.celebud.com" }],
      "destination": "https://celebud.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://ucsuyrhlhmqezubfoszx.supabase.co/functions/v1/generate-sitemap"
    },
    {
      "source": "/article/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|yandex|duckduckbot|baiduspider|facebookexternalhit|facebookcatalog|twitterbot|linkedinbot|slackbot|discordbot|whatsapp|telegrambot|pinterest|redditbot|applebot|petalbot).*"
        }
      ],
      "destination": "https://ucsuyrhlhmqezubfoszx.supabase.co/functions/v1/prerender?path=/article/$1"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|yandex|duckduckbot|baiduspider|facebookexternalhit|facebookcatalog|twitterbot|linkedinbot|slackbot|discordbot|whatsapp|telegrambot|pinterest|redditbot|applebot|petalbot).*"
        }
      ],
      "destination": "https://ucsuyrhlhmqezubfoszx.supabase.co/functions/v1/prerender?path=/"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/ads.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
