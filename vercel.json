{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://mmqpdaavpcvbsqgpvlsu.supabase.co/functions/v1/generate-sitemap"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/ads.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
